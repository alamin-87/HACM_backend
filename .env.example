# MongoDB connection string
# Local:                mongodb://localhost:27017/hacm_annotation
# MongoDB Atlas (cloud): mongodb+srv://<user>:<password>@<cluster>.mongodb.net/hacm_annotation
MONGO_URI=mongodb+srv://XXXXXXX:XXXXX@cluster0.umfqodo.mongodb.net/?appName=Cluster0

# Server port
PORT=4000

# How many people must annotate each image before it's hidden
MAX_ANNOTATORS=5

# How many images to send per session/batch
BATCH_SIZE=30

# ── Google Drive Integration ──────────────────────────────────
# Get an API key from: https://console.cloud.google.com/apis/credentials
# Make sure "Google Drive API" is enabled in your Google Cloud project.
GOOGLE_API_KEY=AIzaSyCKsqrcXXXXXXXXXXXXXXXXX

# The root Drive folder ID (the part after /folders/ in the URL)
GOOGLE_DRIVE_FOLDER_ID=1t9bfqLNLhUZZtXXXXXXXXXXXXX
